Output demo.gif

Set Shell bash
Set FontSize 14
Set Width 1500
Set Height 820
Set Padding 12

Type "cq"
Sleep 700ms
Enter
Sleep 2.2s

# Show additional info
Type "i"
Sleep 1.4s

# Close modal
Type "esc"
Sleep 1.1s

# Switch account and show another quota profile
Type "l"
Sleep 1.9s

# Show additional info on second account
Type "i"
Sleep 1.4s

Type "esc"
Sleep 1.0s

Type "q"
Sleep 600ms
